{
  "name": "@paolojulian.dev/design-system",
  "license": "MIT",
  "private": false,
  "version": "4.6.3",
  "type": "module",
  "types": "dist/index.d.ts",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.es.js",
      "require": "./dist/constants.cjs.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.es.js",
      "require": "./dist/icons.cjs.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.es.js",
      "require": "./dist/utils.cjs.js"
    },
    "./style.css": "./dist/style.css",
    "./theme.css": "./dist/theme.css",
    "./fonts.css": "./dist/fonts.css",
    "./fonts/*": "./dist/assets/fonts/*",
    "./vite-config/*": "./dist/vite-config/*"
  },
  "files": [
    "/dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/paolojulian/design-system.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:storybook": "storybook build",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "test:ui": "playwright test",
    "test:ui:build": "npm run build:storybook && playwright test",
    "test:visual": "npm run build:storybook && chromatic --storybook-build-dir storybook-static --only-changed",
    "test:visual:ci": "chromatic --storybook-build-dir storybook-static --only-changed --ci --exit-once-uploaded",
    "publish:pack": "yarn build && npm pack --pack-destination ./packed"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@chromatic-com/storybook": "^1.9.0",
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-essentials": "^8.3.1",
    "@storybook/addon-interactions": "^8.3.1",
    "@storybook/addon-links": "^8.3.1",
    "@storybook/addon-onboarding": "^8.3.1",
    "@storybook/blocks": "^8.3.1",
    "@storybook/react": "^8.3.1",
    "@storybook/react-vite": "^8.3.1",
    "@storybook/test": "^8.3.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "eslint-plugin-storybook": "^0.8.0",
    "globals": "^15.9.0",
    "storybook": "^8.3.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1",
    "vite-plugin-dts": "^4.2.1",
    "vite-plugin-static-copy": "^1.0.6"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
